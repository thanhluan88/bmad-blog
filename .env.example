# Database (local: use scripts/start-postgres.ps1; prod: Neon)
# App/runtime on Neon: use the *pooled* connection string (host contains `-pooler`).
DATABASE_URL="postgresql://simple_blog:simple_blog@localhost:5432/simple_blog?schema=public"
# Migrations only (optional on Neon): direct connection without `-pooler` in the host.
# If omitted, `npm run db:deploy` auto-strips `-pooler` from DATABASE_URL.
# DIRECT_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js - generate secret: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

# Vercel Blob (cover image upload) - create Blob store in Vercel Dashboard → Storage
# Token is auto-added when you create a store. For local: vercel env pull
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# PMP Mock Exam settings (optional, defaults: 180 questions, 240 minutes)
# NEXT_PUBLIC_PMP_EXAM_QUESTIONS=180
# NEXT_PUBLIC_PMP_EXAM_MINUTES=240
